{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/azhansy/ds-tvbox/main/schemas/depot.schema.json",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["urls"],
      "properties": {
        "urls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "url"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "pattern": "^https://" }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["storeHouse"],
      "properties": {
        "storeHouse": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sourceName", "sourceUrl"],
            "properties": {
              "sourceName": { "type": "string", "minLength": 1 },
              "sourceUrl": { "type": "string", "pattern": "^https://" }
            }
          }
        }
      }
    }
  ]
}
